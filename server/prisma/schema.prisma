// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         Int      @id
  nombre     String
  correo     String   @unique
  password   String
  rol        String   @default("Operativo")
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("users")
}

model Product {
  id              Int      @id @default(autoincrement())
  nombre          String
  descripcion     String?
  tienda          String?  // Nombre de categoría
  flag            String?
  preventa_inicio DateTime?
  preventa_fin    DateTime?
  precio          Float?
  stock           Int?
  envio_especial  Float?
  peso            Float?
  es_variable     Boolean  @default(false)
  es_publico      Boolean  @default(true)
  es_publico_pos  Boolean  @default(true)
  slug            String   @unique
  imagen_url      String?
  galeria_urls    String[]
  atributos       Json?    // Array of attributes
  numero_serie    String?
  codigo_barras   String?
  costo_real      Float?
  variaciones     ProductVariation[]
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@map("products")
}

model ProductVariation {
  id         Int      @id @default(autoincrement())
  product_id Int
  valor      String
  precio     Float?
  stock      Int?
  color      String?
  imagen_url String?
  costo_real Float?

  product    Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@map("product_variations")
}

// ─── Categorias ────────────────────────────────────────────────────────────────
model Categoria {
  id         Int      @id @default(autoincrement())
  nombre     String
  imagen_url String?
  publico    Boolean  @default(false)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("categorias")
}

// ─── Clientes ──────────────────────────────────────────────────────────────────
model Cliente {
  id         Int      @id @default(autoincrement())
  nombre     String
  correo     String   @unique
  telefono   String?
  pedidos    Pedido[]
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("clientes")
}

// ─── Pedidos ───────────────────────────────────────────────────────────────────
model Pedido {
  id         Int          @id @default(autoincrement())
  orden      String       @unique           // Número visible, ej "ORD-1001"
  cliente_id Int?
  nombre     String                         // Nombre del comprador (desnormalizado)
  correo     String                         // Correo del comprador
  telefono   String?
  ciudad     String?
  domicilio  String?
  notas       String?
  estado      String       @default("Nuevo") // Nuevo | En proceso | Completado | Fallido | Cancelado
  envio       Float        @default(0)
  total       Float
  metodo_pago String       @default("Tarjeta de Crédito") // Tarjeta de Crédito | Tarjeta de Débito | Efectivo | Transferencia
  canal_venta String       @default("Tienda en Línea")   // Tienda en Línea | POS
  items       PedidoItem[]
  cliente     Cliente?     @relation(fields: [cliente_id], references: [id], onDelete: SetNull)
  created_at  DateTime     @default(now())
  updated_at  DateTime     @updatedAt

  @@map("pedidos")
}

model PedidoItem {
  id         Int    @id @default(autoincrement())
  pedido_id  Int
  nombre     String
  variante   String?
  cantidad   Int    @default(1)
  precio     Float
  imagen     String?
  pedido     Pedido @relation(fields: [pedido_id], references: [id], onDelete: Cascade)

  @@map("pedido_items")
}

// ─── Inventario ────────────────────────────────────────────────────────────────
// Vista lógica — el inventario se calcula a partir de products y product_variations.
// Esta tabla guarda movimientos manuales de ajuste de stock (entradas/salidas).
model InventarioMovimiento {
  id          Int      @id @default(autoincrement())
  product_id  Int
  tipo        String   // "entrada" | "salida" | "ajuste"
  cantidad    Int
  motivo      String?
  created_at  DateTime @default(now())

  @@map("inventario")
}

// ─── Taller ────────────────────────────────────────────────────────────────────
model OrdenTaller {
  id          Int      @id @default(autoincrement())
  numero      String   @unique
  cliente     String
  bicicleta   String?
  telefono    String?
  descripcion String
  costo       Float
  servicio    String?
  estado      String   @default("recibido") // recibido | en_progreso | para_entrega
  fecha       String?  // Ej. "10:00"
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@map("ordenes_taller")
}

// ─── Gastos ────────────────────────────────────────────────────────────────────
model Gasto {
  id          Int      @id @default(autoincrement())
  concepto    String
  monto       Float
  categoria   String
  fecha       DateTime @default(now())
  notas       String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@map("gastos")
}

